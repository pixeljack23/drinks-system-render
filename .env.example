SPRING_PROFILES_ACTIVE=supabase

# Use the Supabase session pooler connection string for a persistent Spring server.
# Example:
# jdbc:postgresql://aws-0-us-east-1.pooler.supabase.com:5432/postgres?user=postgres.xxxxx
SUPABASE_DB_URL=jdbc:postgresql://YOUR-SUPABASE-HOST:5432/postgres
SUPABASE_DB_USER=postgres.YOUR_PROJECT_REF
SUPABASE_DB_PASSWORD=YOUR_DATABASE_PASSWORD

SUPABASE_DB_MAX_POOL_SIZE=10
SUPABASE_DB_MIN_IDLE=2
SUPABASE_DB_CONNECTION_TIMEOUT_MS=30000
